{
  "name": "webmcp-next",
  "version": "0.1.0",
  "description": "Next.js plugin for WebMCP - expose API routes, server actions, and data as MCP tools and resources",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "zod": ">=3.0.0",
    "next-safe-action": ">=7.0.0",
    "next-zod-route": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "next-safe-action": {
      "optional": true
    },
    "next-zod-route": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
